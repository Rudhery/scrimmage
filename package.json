{
  "name": "scrimmage",
  "version": "0.1.0",
  "private": true,
  "description": "Schedule and manage friendly matches (scrims) between teams, right from Discord.",
  "type": "module",
  "license": "MIT",
  "author": "Rudhery Hotz",
  "homepage": "https://github.com/Rudhery/scrimmage#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rudhery/scrimmage.git"
  },
  "bugs": {
    "url": "https://github.com/Rudhery/scrimmage/issues"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "discord.js",
    "scrim",
    "scrimmage",
    "matchmaking",
    "scheduling",
    "esports",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.3.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "dev": "npm run dev --workspace @scrimmage/bot",
    "start": "npm run start --workspace @scrimmage/bot",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "npm run db:generate --workspace @scrimmage/storage-sqlite",
    "db:migrate": "npm run db:migrate --workspace @scrimmage/storage-sqlite",
    "changeset": "changeset",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^3.0.5",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.5"
  }
}
