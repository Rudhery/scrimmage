# ---------------------------------------------------------------------------
# Scrimmage — environment configuration
# Copy this file to `.env` and fill in your own values.
# ---------------------------------------------------------------------------

# Discord application credentials.
# Create an application at https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-application-id-here

# Optional: register slash commands to a single guild for instant updates while
# developing. Leave empty to register commands globally (can take up to ~1 hour
# to propagate across Discord).
DISCORD_GUILD_ID=

# Optional: enable "Login with Discord" on the web dashboard. Set the client
# secret (from the Developer Portal) and add the redirect URI below to your
# app's OAuth2 settings. Without these, the dashboard runs open (enter a guild ID).
DISCORD_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/callback

# Path to the SQLite database file (created automatically on first run).
DATABASE_PATH=./scrimmage.sqlite

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Pre-game reminders: how many minutes before kickoff to notify the teams, and
# how often (in seconds) the bot checks for scrimmages that are due.
REMINDER_LEAD_MINUTES=15
REMINDER_POLL_SECONDS=60
